{
  "name": "swarm-argus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "3D observability for Claude Code agent swarms — live view, inspect, replay.",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "install-hooks": "node scripts/install-hooks.mjs",
    "uninstall-hooks": "node scripts/uninstall-hooks.mjs"
  },
  "dependencies": {
    "3d-force-graph": "^1.73.4",
    "chokidar": "^3.6.0",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1",
    "ws": "^8.18.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^2.0.3"
  }
}
